# ─── Expo / React Native env vars ────────────────────────────────────────────
# Copy this file to .env and fill in your Render deployment URL.
# All EXPO_PUBLIC_* vars are bundled into the app at build time — never put
# secrets here.

# Your Render API server URL (no trailing slash).
# Local dev:   http://localhost:3000
# Production:  https://lumble.onrender.com
EXPO_PUBLIC_API_URL=https://lumble.onrender.com
